<launch>
    <!-- 1. 定义路径变量 -->
    <let name="urdf_path" value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro"/>
    <let name="controllers_config_path" value="$(find-pkg-share my_robot_bringup)/config/ros2_controllers.yaml"/>
    <let name="rviz_config_path" value="$(find-pkg-share my_robot_bringup)/config/my_robot_moveit.rviz"/>

    <!-- 2. 启动 robot_state_publisher -->
    <!-- 解析 xacro 并发布机器人描述 -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')"/>
    </node>

    <!-- 3. 启动 ros2_control_node (控制器管理器) -->
    <!-- 需要加载 URDF 参数和控制器配置文件 -->
    <node pkg="controller_manager" exec="ros2_control_node">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')"/>
        <param from="$(var controllers_config_path)"/>
    </node>

    <!-- 4. 启动各个控制器 -->
    <!-- 注意：spawner 实际上也是一个节点 -->
    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster"/>
    <node pkg="controller_manager" exec="spawner" args="arm_controller"/>
    <node pkg="controller_manager" exec="spawner" args="gripper_controller"/>

    <!-- 5. 启动 MoveIt move_group -->
    <include file="$(find-pkg-share my_robot_moveit_config)/launch/move_group.launch.py"/>

    <node pkg="my_robot_commander_cpp" exec="commander"/>

    <!-- 6. 启动 RViz -->
    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_config_path)"/>

</launch>